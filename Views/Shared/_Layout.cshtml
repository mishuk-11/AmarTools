<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AmarTools InvoiceGenerator</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Invoice" asp-action="Generate">AmarTools InvoiceGenerator</a>
            <div class="navbar-nav">
                <a class="nav-link text-white" asp-controller="Invoice" asp-action="Generate">New Invoice</a>
                <a class="nav-link text-white" asp-controller="Invoice" asp-action="History">History</a>
            </div>
        </div>
    </nav>
    <main role="main" class="container-fluid px-4">
        @RenderBody()
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- HTMX from CDN — fixes all hx-post buttons -->
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>