@model IEnumerable<AmrTools.Models.User>
@{
    Layout = "_AdminLayout"; 
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid mt-5 pt-4 px-lg-5">
    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-xl-4">
            <div class="card shadow-sm border-0 h-100 position-relative overflow-hidden" style="background: linear-gradient(45deg, #4e73df, #224abe); color: white;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase fw-bold opacity-75 small mb-1">Total Users</h6>
                            <h2 class="display-6 fw-bold mb-0">@ViewBag.TotalUsers</h2>
                        </div>
                        <div class="icon-shape">
                            <i class="bi bi-people-fill fs-1 opacity-25"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-12 col-sm-6 col-xl-4">
            <div class="card shadow-sm border-0 h-100 position-relative overflow-hidden" style="background: linear-gradient(45deg, #f6ad55, #ed8936); color: white;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase fw-bold opacity-75 small mb-1">Pro Users</h6>
                            <h2 class="display-6 fw-bold mb-0">@ViewBag.ProUsers</h2>
                        </div>
                        <div class="icon-shape">
                            <i class="bi bi-crown-fill fs-1 opacity-25"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-4 mt-2">
            <div class="card shadow-sm border-0 h-100 position-relative overflow-hidden" style="background: linear-gradient(45deg, #48bb78, #38a169); color: white;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase fw-bold opacity-75 small mb-1">Free Users</h6>
                            <h2 class="display-6 fw-bold mb-0">@ViewBag.FreeUsers</h2>
                        </div>
                        <div class="icon-shape">
                            <i class="bi bi-person-check fs-1 opacity-25"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow border-0 rounded-3">
        <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between">
            <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-shield-lock me-2"></i>User Management</h5>
            <span class="badge bg-light text-dark border">Updated Just Now</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4 py-3 border-0 small text-uppercase fw-bold">User Info</th>
                            <th class="py-3 border-0 small text-uppercase fw-bold d-none d-md-table-cell">Email</th>
                            <th class="py-3 border-0 small text-uppercase fw-bold">Plan</th>
                            <th class="py-3 border-0 small text-uppercase fw-bold text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-3 bg-light text-primary fw-bold">
                                            @user.FullName.Substring(0, 1)
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@user.FullName</div>
                                            <div class="small text-muted d-md-none">@user.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-3 d-none d-md-table-cell text-muted">@user.Email</td>
                                <td class="py-3">
                                    @if(user.SubscriptionPlan == "Pro") {
                                        <span class="badge rounded-pill bg-warning-soft text-warning border border-warning">
                                            <i class="bi bi-star-fill me-1"></i> PRO
                                        </span>
                                    } else {
                                        <span class="badge rounded-pill bg-light text-secondary border">FREE</span>
                                    }
                                </td>
                                <td class="py-3 text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        @if (user.SubscriptionPlan != "Pro")
                                        {
                                            <form asp-action="MakePro" method="post" class="m-0">
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-success rounded-pill px-3" title="Upgrade to Pro">
                                                    <i class="bi bi-arrow-up"></i> <span class="d-none d-sm-inline">Pro</span>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="MakeFree" method="post" class="m-0">
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-secondary rounded-pill px-3" title="Downgrade to Free">
                                                    <i class="bi bi-arrow-down"></i> <span class="d-none d-sm-inline">Free</span>
                                                </button>
                                            </form>
                                        }

                                        <form asp-action="DeleteUser" method="post" class="m-0" onsubmit="return confirm('Delete this user?')">
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button type="submit" class="btn btn-sm btn-light text-danger border-0 rounded-circle p-2" title="Delete User">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    
    .avatar-circle {
        width: 35px;
        height: 35px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
    }
    
    .bg-warning-soft { background-color: #fff9eb; }
    
    .card { transition: all 0.3s ease; }
    
    
    @@media (max-width: 576px) {
        .display-6 { font-size: 1.8rem; }
        .table { font-size: 14px; }
    }
</style>