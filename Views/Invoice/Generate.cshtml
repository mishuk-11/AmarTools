@model AmarTools.InvoiceGenerator.Models.InvoiceViewModel
@using Microsoft.AspNetCore.Mvc.ViewFeatures

@{
    ViewData["Title"] = "Create Invoice - Invofy";
}

<div class="container-fluid py-4">
    <div class="row">
        <!-- Left Side: Form -->
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Create New Invoice</h4>
                </div>
                <div class="card-body">

                    <!-- MAIN FORM (Save works correctly) -->
                    <form id="invoiceForm"
                          asp-action="Save"
                          asp-controller="Invoice"
                          method="post">

                        @Html.AntiForgeryToken()
                        <!-- Flag to indicate this is a draft save. Set to true when Save for Later is clicked. -->
                        <input type="hidden" id="IsDraft" name="IsDraft" value="false" />

                        <!-- HTMX LIVE PREVIEW WRAPPER (this was the bug) -->
                        <div id="livePreviewTrigger"
                             hx-post="@Url.Action("UpdatePreview", "Invoice")"
                             hx-trigger="change, keyup delay:500ms"
                             hx-target="#previewContainer"
                             hx-swap="innerHTML"
                             hx-include="#invoiceForm">

                            <!-- FROM & TO -->
                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <h5 class="mb-3">Bill From (Your Info)</h5>
                                    @{
                                        var fromViewData = new ViewDataDictionary(ViewData) { { "Prefix", "From" } };
                                    }
                                    <partial name="_CompanyForm" model="Model.From" view-data="fromViewData" />
                                </div>
                                <div class="col-md-6">
                                    <h5 class="mb-3">Bill To (Client Info)</h5>
                                    @{
                                        var toViewData = new ViewDataDictionary(ViewData) { { "Prefix", "To" } };
                                    }
                                    <partial name="_CompanyForm" model="Model.To" view-data="toViewData" />
                                </div>
                            </div>

                            <!-- INVOICE DETAILS -->
                            <div class="mb-4">
                                <h5>Invoice Details</h5>
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label asp-for="InvoiceNumber" class="form-label"></label>
                                        <input asp-for="InvoiceNumber" class="form-control" />
                                    </div>
                                    <div class="col-md-4">
                                        <label asp-for="IssueDate" class="form-label"></label>
                                        <input asp-for="IssueDate" class="form-control" type="date" />
                                    </div>
                                    <div class="col-md-4">
                                        <label asp-for="DueDate" class="form-label"></label>
                                        <input asp-for="DueDate" class="form-control" type="date" />
                                    </div>
                                </div>
                            </div>

                            <!-- LINE ITEMS -->
                            <div class="mb-4">
                                <h5>Items / Services</h5>
                                <div id="lineItemsContainer">
                                    <partial name="_LineItemsTable" model="Model" />
                                </div>
                                <button type="button"
                                        hx-post="@Url.Action("AddItem", "Invoice")"
                                        hx-include="#invoiceForm"
                                        hx-target="#lineItemsContainer"
                                        hx-swap="innerHTML"
                                        class="btn btn-outline-primary mt-2">
                                    + Add Item
                                </button>
                            </div>

                            <!-- TAX, DISCOUNT & NOTES -->
                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label asp-for="TaxRate" class="form-label"></label>
                                    <div class="input-group">
                                        <input asp-for="TaxRate" class="form-control" type="number" step="0.01" min="0" max="100" />
                                        <span class="input-group-text">%</span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="DiscountAmount" class="form-label"></label>
                                    <input asp-for="DiscountAmount" class="form-control" type="number" step="0.01" min="0" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Notes" class="form-label"></label>
                                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Terms" class="form-label"></label>
                                <textarea asp-for="Terms" class="form-control" rows="2"></textarea>
                            </div>

                        </div> <!-- End of HTMX wrapper -->
                        <!-- ACTION BUTTONS (outside HTMX so Save works) -->
                        <div class="d-flex gap-3 mt-4">
                            <button type="submit"
                                    class="btn btn-success flex-fill py-3"
                                    onclick="document.getElementById('IsDraft').value = 'true';">
                                <i class="bi bi-save me-2"></i> Save for Later
                            </button>

                            <button type="button"
                                    onclick="generatePdf()"
                                    class="btn btn-primary flex-fill py-3">
                                <i class="bi bi-file-earmark-pdf me-2"></i> Generate PDF
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>

        <!-- Right Side: Live Preview -->
        <div class="col-lg-5">
            <div class="card shadow-sm sticky-top" style="top: 20px;">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Live Preview</h5>
                </div>
                <div class="card-body p-0">
                    <div id="previewContainer">
                        <partial name="_LivePreview" model="Model" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function generatePdf() {
            const form = document.getElementById('invoiceForm');
            const formData = new FormData(form);
            fetch('@Url.Action("GeneratePdf", "Invoice")', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (response.ok) return response.blob();
                return response.text().then(text => { throw new Error(text); });
            })
            .then(blob => {
                const url = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = (document.querySelector('[name="InvoiceNumber"]')?.value || 'invoice') + '.pdf';
                a.click();
                window.URL.revokeObjectURL(url);
            })
            .catch(err => alert('Error generating PDF: ' + err.message));
        }
    </script>
}