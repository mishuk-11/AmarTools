@{
    ViewData["Title"] = "SEO Keyword Finder";
}

<div class="container mt-5">
    <div class="card shadow border-0">
        <div class="card-body p-5">
            <h2 class="text-center mb-4"><i class="bi bi-search text-success"></i> SEO Keyword Finder</h2>
            <p class="text-center text-muted">Enter a seed word to find trending search suggestions from Google.</p>

            <form method="post">
                <div class="input-group mb-3">
                    <input type="text" name="seedKeyword" class="form-control form-control-lg" placeholder="e.g., Laravel Tutorial" required />
                    <button class="btn btn-success px-4" type="submit">Find Keywords</button>
                </div>
            </form>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger mt-3">@ViewBag.Error</div>
            }

            @if (ViewBag.Keywords != null)
            {
                <div class="mt-4">
                    <h4>Results for: <span class="text-primary">@ViewBag.Seed</span></h4>
                    <hr />
                    <div class="list-group">
                        @foreach (var kw in ViewBag.Keywords)
                        {
                            <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                @kw
                                <button class="btn btn-sm btn-outline-secondary" onclick="navigator.clipboard.writeText('@kw')">
                                    <i class="bi bi-clipboard"></i> Copy
                                </button>
                            </div>
                        }
                    </div>
                    
                    <button class="btn btn-dark mt-3" onclick="copyAll()">Copy All Keywords</button>
                </div>
            }
        </div>
    </div>
</div>

<script>
    function copyAll() {
        let keywords = [];
        document.querySelectorAll('.list-group-item').forEach(item => {
            keywords.push(item.innerText.replace(' Copy', '').trim());
        });
        navigator.clipboard.writeText(keywords.join(', '));
        alert('All keywords copied to clipboard!');
    }
</script>