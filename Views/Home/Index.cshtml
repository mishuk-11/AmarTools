@{
    ViewData["Title"] = "AmarTools - Free Invoice Generator";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 text-center">
            <!-- Hero Section -->
            <div class="mb-5">
                <h1 class="display-4 fw-bold text-primary mb-3">
                    Create Professional Invoices in Seconds
                </h1>
                <p class="lead text-muted mb-4">
                    Free • No Sign-up Required • Instant PDF Download
                </p>
                
                <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                    <a asp-controller="Invoice" asp-action="Generate" 
                       class="btn btn-primary btn-lg px-5 py-3">
                        <i class="bi bi-plus-circle me-2"></i>
                        Create New Invoice
                    </a>
                    
                    <a asp-controller="Invoice" asp-action="History" 
                       class="btn btn-outline-secondary btn-lg px-5 py-3">
                        <i class="bi bi-clock-history me-2"></i>
                        View Invoice History
                    </a>
                </div>
            </div>

            <!-- Features -->
            <div class="row g-4 mt-5">
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body text-center py-4">
                            <div class="text-primary mb-3">
                                <i class="bi bi-lightning-charge-fill fs-1"></i>
                            </div>
                            <h5>Lightning Fast</h5>
                            <p class="text-muted">Live preview updates instantly as you type. No page reloads.</p>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body text-center py-4">
                            <div class="text-primary mb-3">
                                <i class="bi bi-file-earmark-pdf-fill fs-1"></i>
                            </div>
                            <h5>Beautiful PDFs</h5>
                            <p class="text-muted">Clean, professional invoice PDFs generated with QuestPDF.</p>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body text-center py-4">
                            <div class="text-primary mb-3">
                                <i class="bi bi-database-fill fs-1"></i>
                            </div>
                            <h5>Save for Later</h5>
                            <p class="text-muted">Save invoices to your history and load them anytime.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Call to Action -->
            <div class="mt-5 pt-4 border-top">
                <p class="text-muted">
                    Built with ASP.NET MVC • HTMX • Bootstrap • QuestPDF
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .display-4 {
        font-size: 2.8rem;
    }
    
    .card {
        transition: transform 0.2s;
    }
    
    .card:hover {
        transform: translateY(-5px);
    }
</style>