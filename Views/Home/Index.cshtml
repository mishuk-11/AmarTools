@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <h2>Welcome, @Context.Session.GetString("UserName")</h2>
            <p class="text-muted">Choose a tool to get started with your project.</p>
            <hr />
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center">
                    <i class="bi bi-youtube text-danger" style="font-size: 3rem;"></i>
                    <h5 class="card-title mt-3">YouTube Thumbnail</h5>
                    <p class="card-text text-muted">Download high-quality thumbnails from any YouTube video.</p>
                    <a href="/Tools/YouTubeThumbnail" class="btn btn-outline-primary w-100">Open Tool</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center">
                    <i class="bi bi-image-fill text-primary" style="font-size: 3rem;"></i>
                    <h5 class="card-title mt-3">Image Resizer</h5>
                    <p class="card-text text-muted">Quickly resize your images for social media or web.</p>
                    <a href="/Tools/ImageResize" class="btn btn-outline-primary w-100">Open Tool</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center">
                    <i class="bi bi-search text-success" style="font-size: 3rem;"></i>
                    <h5 class="card-title mt-3">SEO Keywords</h5>
                    <p class="card-text text-muted">Find the best keywords to rank your content higher.</p>
                    <a href="/Tools/Keywords" class="btn btn-outline-primary w-100">Open Tool</a>
                </div>
            </div>
        </div>
    </div>
</div>