@{
    ViewData["Title"] = "Pricing Plans";
}

<div class="container mt-5 text-center">
    <h2>Choose Your Plan</h2>
    <div class="row mt-4">
        <div class="col-md-6 border p-4">
            <h3>Free Plan</h3>
            <p>Basic Access</p>
            <button class="btn btn-secondary" disabled>Current</button>
        </div>
        <div class="col-md-6 border p-4 bg-light">
            <h3>Pro Plan ($9/mo)</h3>
            <p>Unlimited Access</p>
            <a href="/Home/Upgrade" class="btn btn-primary">Upgrade Now</a>
        </div>
    </div>
</div>