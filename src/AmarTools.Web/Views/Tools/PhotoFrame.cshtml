@{
    ViewData["Title"] = "Photo Frame";
    ViewData["ActivePage"] = "photoframe";
    Layout = "~/Views/Shared/Tools_Layout.cshtml";
}
<script>Auth.guard('User');</script>

<style>
  .page-title{font-size:20px;font-weight:800;color:#3e256c;margin-bottom:4px;}
  .page-sub{font-size:13px;color:#6b7280;margin-bottom:24px;}
  .card{background:#fff;border:1px solid #ede8f5;border-radius:14px;padding:24px;margin-bottom:18px;}
  .card-title{font-size:14px;font-weight:700;color:#3e256c;margin-bottom:14px;display:flex;align-items:center;gap:8px;}
  .form-group{margin-bottom:13px;}
  .form-label{display:block;font-size:11px;font-weight:700;color:#6b7280;margin-bottom:5px;text-transform:uppercase;letter-spacing:.4px;}
  .form-input{width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:13px;background:#fafafa;box-sizing:border-box;}
  .form-input:focus{outline:none;border-color:#6252a3;background:#fff;}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
  .select-input{width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:13px;background:#fafafa;box-sizing:border-box;}
  .select-input:focus{outline:none;border-color:#6252a3;}
  .btn{padding:10px 20px;border:none;border-radius:9px;font-size:13px;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:all .15s;}
  .btn:hover{opacity:.88;}
  .btn:disabled{opacity:.5;cursor:not-allowed;}
  .btn-primary{background:linear-gradient(135deg,#3e256c,#6252a3);color:#fff;}
  .btn-ghost{background:#f3f4f6;color:#374151;border:1px solid #e5e7eb;}
  .btn-save{background:linear-gradient(135deg,#2563eb,#3b82f6);color:#fff;padding:11px 22px;}
  .btn-publish{background:linear-gradient(135deg,#059669,#10b981);color:#fff;padding:11px 22px;}
  .btn-edit{background:#fff;color:#3e256c;border:1.5px solid #6252a3;padding:9px 18px;}
  .btn-edit:hover{background:#f5f3ff;}
  .btn-danger{background:#fff;color:#dc2626;border:1.5px solid #fca5a5;padding:9px 18px;}
  .btn-danger:hover{background:#fef2f2;}

  /* Upload boxes */
  .upload-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px;}
  .upload-card{background:#fff;border:1px solid #ede8f5;border-radius:14px;padding:20px;}
  .upload-card-title{font-size:13px;font-weight:700;color:#3e256c;margin-bottom:4px;display:flex;align-items:center;gap:7px;}
  .upload-card-sub{font-size:11px;color:#9ca3af;margin-bottom:14px;}
  .upload-drop{border:2px dashed #e5e7eb;border-radius:10px;min-height:130px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:border-color .15s,background .15s;position:relative;overflow:hidden;}
  .upload-drop:hover{border-color:#6252a3;background:#faf8ff;}
  .upload-drop.has-file{border-color:#10b981;border-style:solid;background:#f0fdf4;}
  .upload-drop input{display:none;}
  .upload-hint{display:flex;flex-direction:column;align-items:center;gap:6px;pointer-events:none;}
  .upload-hint-text{font-size:12px;color:#9ca3af;}
  .upload-hint-sub{font-size:11px;color:#c4b5d5;}
  .upload-preview{width:100%;height:130px;object-fit:contain;border-radius:8px;display:none;padding:4px;}

  /* Alert */
  .alert{padding:11px 14px;border-radius:9px;font-size:13px;margin-bottom:16px;display:none;}
  .alert-success{background:#f0fdf4;color:#166534;border:1px solid #bbf7d0;}
  .alert-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca;}

  /* Live banner */
  .live-banner{background:linear-gradient(135deg,#f0fdf4,#dcfce7);border:2px solid #10b981;border-radius:16px;padding:24px;margin-bottom:18px;}
  .live-banner-top{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap;}
  .live-banner-left{flex:1;}
  .live-badge{display:inline-flex;align-items:center;gap:7px;background:#10b981;color:#fff;font-size:12px;font-weight:700;padding:4px 12px;border-radius:20px;margin-bottom:10px;}
  .live-title{font-size:17px;font-weight:800;color:#065f46;margin-bottom:6px;}
  .live-sub{font-size:12px;color:#047857;margin-bottom:16px;}
  .url-row{display:flex;gap:8px;max-width:480px;margin-bottom:12px;}
  .url-input{flex:1;padding:10px 13px;border:1.5px solid #a7f3d0;border-radius:9px;font-size:12px;background:#fff;font-family:monospace;color:#065f46;}
  .btn-copy{padding:10px 16px;background:#10b981;color:#fff;border:none;border-radius:9px;font-size:12px;font-weight:700;cursor:pointer;white-space:nowrap;}
  .btn-copy:hover{background:#059669;}
  .kiosk-open{display:inline-flex;align-items:center;gap:5px;color:#059669;font-size:13px;font-weight:700;text-decoration:none;}
  .kiosk-open:hover{text-decoration:underline;}
  .live-dot{width:8px;height:8px;background:#fff;border-radius:50%;animation:livePulse 1.5s infinite;}
  @@keyframes livePulse{0%,100%{opacity:1}50%{opacity:.4}}

  /* Draft banner */
  .draft-banner{background:linear-gradient(135deg,#eff6ff,#dbeafe);border:2px solid #3b82f6;border-radius:16px;padding:20px;margin-bottom:18px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;}
  .draft-badge{display:inline-flex;align-items:center;gap:6px;background:#2563eb;color:#fff;font-size:12px;font-weight:700;padding:4px 12px;border-radius:20px;}
  .draft-info{font-size:13px;color:#1d4ed8;font-weight:600;}
  .draft-sub{font-size:12px;color:#3b82f6;margin-top:2px;}

  /* Action row */
  .action-row{display:flex;gap:10px;flex-wrap:wrap;align-items:center;}

  /* Spinner */
  .spinner{width:16px;height:16px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;display:inline-block;}
  @@keyframes spin{to{transform:rotate(360deg)}}

  @@media(max-width:700px){
    .upload-grid{grid-template-columns:1fr;}
    .form-row{grid-template-columns:1fr;}
    .url-row{flex-direction:column;}
    .live-banner-top{flex-direction:column;}
  }
</style>

<h1 class="page-title">Photo Frame Kiosk</h1>
<p class="page-sub">Create a public kiosk where guests upload their photo and download it framed.</p>

<div id="alertMsg" class="alert"></div>

<!-- Step 1: Event -->
<div class="card">
  <div class="card-title">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    1 · Select Event
  </div>
  <div class="form-group" style="margin:0;">
    <label class="form-label">Active Event</label>
    <select id="eventSelect" class="select-input" onchange="onEventChange()">
      <option value="">— Choose an event —</option>
    </select>
  </div>
</div>

<!-- Setup (hidden until event selected) -->
<div id="setupSection" style="display:none;">

  <!-- Live banner -->
  <div id="liveBanner" style="display:none;" class="live-banner">
    <div class="live-banner-top">
      <div class="live-banner-left">
        <div style="margin-bottom:8px;"><span class="live-badge"><span class="live-dot"></span>LIVE</span></div>
        <div class="live-title">Kiosk is Live!</div>
        <div class="live-sub">Share this link with guests — they can upload and download their framed photo.</div>
        <div class="url-row">
          <input class="url-input" id="kioskUrlInput" readonly />
          <button class="btn-copy" onclick="copyKioskUrl()">Copy</button>
        </div>
        <a id="kioskOpenLink" class="kiosk-open" href="#" target="_blank">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Open Kiosk
        </a>
      </div>
      <div style="display:flex;flex-direction:column;gap:8px;flex-shrink:0;">
        <button class="btn btn-edit" onclick="editSettings()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          Edit Settings
        </button>
        <button class="btn btn-danger" onclick="unpublish()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
          Unpublish
        </button>
      </div>
    </div>
  </div>

  <!-- Draft banner (saved but not published) -->
  <div id="draftBanner" style="display:none;" class="draft-banner">
    <div>
      <div style="margin-bottom:4px;"><span class="draft-badge">DRAFT</span></div>
      <div class="draft-info">Setup saved — not yet published</div>
      <div class="draft-sub">Upload a frame and click "Publish Kiosk" to go live.</div>
    </div>
    <button class="btn btn-edit" onclick="editSettings()">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      Edit
    </button>
  </div>

  <!-- Editor (shown when creating or editing) -->
  <div id="editorSection">
    <!-- Frame + Logo uploads -->
    <div class="upload-grid">
      <div class="upload-card">
        <div class="upload-card-title">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="12" cy="12" r="3"/></svg>
          Frame Image <span style="color:#ef4444;margin-left:2px;">*</span>
        </div>
        <div class="upload-card-sub">Transparent PNG placed on top of the guest photo.</div>
        <div class="upload-drop" id="frameDrop" onclick="document.getElementById('frameFile').click()">
          <input type="file" id="frameFile" accept="image/png,image/jpeg,image/jpg" onchange="onFileSelected('frameFile','framePreview','frameDrop','frameHint','frameStatus')" />
          <div id="frameHint" class="upload-hint">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c4b5d5" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            <span class="upload-hint-text">Click to upload frame</span>
            <span class="upload-hint-sub">PNG with transparency recommended</span>
          </div>
          <img id="framePreview" class="upload-preview" />
        </div>
        <div id="frameStatus" style="font-size:11px;color:#9ca3af;margin-top:7px;display:none;"></div>
      </div>

      <div class="upload-card">
        <div class="upload-card-title">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a4 4 0 0 1 8 0v2"/></svg>
          Event Logo <span style="color:#9ca3af;font-size:11px;font-weight:400;margin-left:4px;">(optional)</span>
        </div>
        <div class="upload-card-sub">Shown on the kiosk page header.</div>
        <div class="upload-drop" id="logoDrop" onclick="document.getElementById('logoFile').click()">
          <input type="file" id="logoFile" accept="image/*" onchange="onFileSelected('logoFile','logoPreview','logoDrop','logoHint','logoStatus')" />
          <div id="logoHint" class="upload-hint">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c4b5d5" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            <span class="upload-hint-text">Click to upload logo</span>
            <span class="upload-hint-sub">PNG, JPG — any size</span>
          </div>
          <img id="logoPreview" class="upload-preview" />
        </div>
        <div id="logoStatus" style="font-size:11px;color:#9ca3af;margin-top:7px;display:none;"></div>
      </div>
    </div>

    <!-- Event details -->
    <div class="card">
      <div class="card-title">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        2 · Event Details
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Event Name <span style="color:#ef4444;">*</span></label>
          <input id="pfEventName" class="form-input" placeholder="e.g. Annual Tech Summit 2025" />
        </div>
        <div class="form-group">
          <label class="form-label">Sponsor / Organiser</label>
          <input id="pfSponsor" class="form-input" placeholder="Optional" />
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Venue</label>
          <input id="pfVenue" class="form-input" placeholder="Optional" />
        </div>
        <div class="form-group">
          <label class="form-label">Event Date / Time</label>
          <input id="pfDateTime" class="form-input" type="datetime-local" />
        </div>
      </div>
    </div>

    <!-- Action buttons -->
    <div class="card" style="padding:20px 24px;">
      <div class="action-row">
        <button id="saveDraftBtn" class="btn btn-save" onclick="saveAll(false)">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          Save Draft
        </button>
        <button id="publishBtn" class="btn btn-publish" onclick="saveAll(true)">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 2L11 13"/><path d="M22 2L15 22 11 13 2 9l20-7z"/></svg>
          Publish Kiosk
        </button>
        <button id="cancelEditBtn" class="btn btn-ghost" onclick="cancelEdit()" style="display:none;">Cancel</button>
      </div>
      <p style="font-size:12px;color:#9ca3af;margin-top:10px;margin-bottom:0;">
        <strong>Save Draft</strong> keeps your settings without going live.
        <strong>Publish Kiosk</strong> saves everything and creates the public link.
      </p>
    </div>
  </div><!-- /editorSection -->

</div><!-- /setupSection -->

<script>
Auth.guard('User');
const token = Auth.getToken();
const H  = { 'Authorization': `Bearer ${token}` };
const HJ = { ...H, 'Content-Type': 'application/json' };
const PHOTO_FRAME_TOOL_TYPE = 1;

let selectedEventToolId = null;
let pfConfigId          = null;
let existingFrameUrl    = null;
let existingSharingSlug = null;
let isPublished         = false;
let isEditing           = false; // true when user clicked "Edit Settings" on a live/draft kiosk

const el = id => document.getElementById(id);

function showAlert(msg, type = 'success') {
  const a = el('alertMsg');
  a.textContent = msg;
  a.className = `alert alert-${type}`;
  a.style.display = 'block';
  a.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  setTimeout(() => a.style.display = 'none', 6000);
}

/* ── Events ── */
async function loadEvents() {
  try {
    const r = await fetch('/api/events', { headers: H });
    if (!r.ok) return;
    const data = await r.json();
    const sel = el('eventSelect');
    data.filter(e => e.status === 1).forEach(e => {
      const o = document.createElement('option');
      o.value = e.id; o.textContent = e.name;
      sel.appendChild(o);
    });
  } catch {}
}

async function onEventChange() {
  const eventId = el('eventSelect').value;
  selectedEventToolId = null; pfConfigId = null;
  existingFrameUrl = null; existingSharingSlug = null;
  isPublished = false; isEditing = false;

  el('setupSection').style.display = eventId ? 'block' : 'none';
  el('liveBanner').style.display   = 'none';
  el('draftBanner').style.display  = 'none';
  el('editorSection').style.display = 'block';
  el('cancelEditBtn').style.display = 'none';

  if (!eventId) return;

  try {
    const r = await fetch(`/api/events/${eventId}/activate-tool/${PHOTO_FRAME_TOOL_TYPE}`, {
      method: 'POST', headers: HJ
    });
    if (r.ok) {
      selectedEventToolId = await r.json();
      await loadExistingSetup();
    } else {
      const text = await r.text().catch(() => '');
      let d = {}; try { d = JSON.parse(text); } catch {}
      showAlert(`Could not activate tool: ${d.detail || d.title || r.status}`, 'error');
      el('setupSection').style.display = 'none';
    }
  } catch (e) { showAlert('Network error: ' + e.message, 'error'); }
}

async function loadExistingSetup() {
  if (!selectedEventToolId) return;
  try {
    const r = await fetch(`/api/photo-frame/setup/${selectedEventToolId}`, { headers: H });
    if (!r.ok) return;
    const d = await r.json();
    pfConfigId          = d.id;
    existingFrameUrl    = d.frameImageUrl;
    existingSharingSlug = d.sharingSlug;
    isPublished         = d.isPublished;

    el('pfEventName').value = d.eventName   || '';
    el('pfSponsor').value   = d.sponsorName || '';
    el('pfVenue').value     = d.venueName   || '';
    if (d.eventDateTime) el('pfDateTime').value = d.eventDateTime.slice(0, 16);

    if (d.frameImageUrl) setPreviewFromUrl('framePreview', 'frameDrop', 'frameHint', 'frameStatus', d.frameImageUrl, 'frame.png');
    if (d.logoImageUrl)  setPreviewFromUrl('logoPreview',  'logoDrop',  'logoHint',  'logoStatus',  d.logoImageUrl,  'logo');

    if (d.isPublished && d.sharingSlug) {
      showLiveBanner(d.sharingSlug);
    } else if (pfConfigId) {
      showDraftBanner();
    }
  } catch {}
}

/* ── File selection ── */
function onFileSelected(inputId, previewId, dropId, hintId, statusId) {
  const file = el(inputId).files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    const img = el(previewId);
    img.src = e.target.result;
    img.style.display = 'block';
    el(hintId).style.display = 'none';
    el(dropId).classList.add('has-file');
    const st = el(statusId);
    st.textContent = `Selected: ${file.name}`;
    st.style.display = 'block'; st.style.color = '#059669';
  };
  reader.readAsDataURL(file);
}

function setPreviewFromUrl(previewId, dropId, hintId, statusId, url, name) {
  const img = el(previewId);
  img.src = url; img.style.display = 'block';
  el(hintId).style.display = 'none';
  el(dropId).classList.add('has-file');
  const st = el(statusId);
  st.textContent = `Uploaded: ${name}`;
  st.style.display = 'block'; st.style.color = '#059669';
}

/* ── Banner helpers ── */
function showLiveBanner(slug) {
  if (!slug) return;
  const url = `${window.location.origin}/kiosk/${slug}`;
  el('kioskUrlInput').value = url;
  el('kioskOpenLink').href  = url;
  el('liveBanner').style.display  = 'block';
  el('draftBanner').style.display = 'none';
  if (!isEditing) el('editorSection').style.display = 'none';
}

function showDraftBanner() {
  el('draftBanner').style.display = 'block';
  el('liveBanner').style.display  = 'none';
  if (!isEditing) el('editorSection').style.display = 'none';
}

function editSettings() {
  isEditing = true;
  el('editorSection').style.display = 'block';
  el('cancelEditBtn').style.display = 'inline-flex';
  el('editorSection').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function cancelEdit() {
  isEditing = false;
  el('cancelEditBtn').style.display = 'none';
  el('editorSection').style.display = 'none';
  if (isPublished) {
    el('liveBanner').style.display = 'block';
  } else {
    el('draftBanner').style.display = pfConfigId ? 'block' : 'none';
  }
}

function copyKioskUrl() {
  const inp = el('kioskUrlInput');
  inp.select(); inp.setSelectionRange(0, 9999);
  navigator.clipboard?.writeText(inp.value).catch(() => document.execCommand('copy'));
  const btn = document.querySelector('.btn-copy');
  const orig = btn.textContent;
  btn.textContent = 'Copied!';
  setTimeout(() => btn.textContent = orig, 2000);
}

/* ── Unpublish ── */
async function unpublish() {
  if (!pfConfigId) return;
  if (!confirm('Take the kiosk offline? Guests will no longer be able to access it.')) return;
  try {
    const r = await fetch(`/api/photo-frame/${pfConfigId}/landing-page`, {
      method: 'PATCH', headers: HJ,
      body: JSON.stringify({
        templateName: 'default', backgroundColor: '#1a1a2e',
        headlineText: el('pfEventName').value.trim() || null,
        instructionText: 'Upload your photo and download your framed picture!',
        downloadButtonText: 'Download My Photo',
        publish: false
      })
    });
    if (r.ok) {
      isPublished = false;
      el('liveBanner').style.display  = 'none';
      el('editorSection').style.display = 'none';
      el('draftBanner').style.display = 'block';
      showAlert('Kiosk unpublished.', 'success');
    } else {
      const text = await r.text().catch(() => '');
      let d = {}; try { d = JSON.parse(text); } catch {}
      showAlert(d.detail || d.title || 'Unpublish failed.', 'error');
    }
  } catch (e) { showAlert('Network error: ' + e.message, 'error'); }
}

/* ── Save / Publish ── */
async function saveAll(shouldPublish) {
  if (!selectedEventToolId) { showAlert('Please select an event first.', 'error'); return; }
  const eventName = el('pfEventName').value.trim();
  if (!eventName) { showAlert('Event name is required.', 'error'); el('pfEventName').focus(); return; }

  const frameFile = el('frameFile').files[0];
  if (shouldPublish && !frameFile && !existingFrameUrl) {
    showAlert('Please upload a frame image before publishing.', 'error'); return;
  }

  const saveDraftBtn  = el('saveDraftBtn');
  const publishBtn    = el('publishBtn');
  const spinner       = '<span class="spinner"></span>';

  saveDraftBtn.disabled = publishBtn.disabled = true;
  if (shouldPublish) {
    publishBtn.innerHTML = `${spinner} Publishing…`;
  } else {
    saveDraftBtn.innerHTML = `${spinner} Saving…`;
  }

  try {
    // 1 — Save / update setup
    let configId = pfConfigId;
    {
      const r = await fetch('/api/photo-frame/setup', {
        method: 'POST', headers: HJ,
        body: JSON.stringify({
          eventToolId:   selectedEventToolId,
          eventName,
          sponsorName:   el('pfSponsor').value.trim() || null,
          venueName:     el('pfVenue').value.trim()   || null,
          eventDateTime: el('pfDateTime').value       || null
        })
      });
      const text = await r.text().catch(() => '');
      let d = {}; try { d = JSON.parse(text); } catch {}
      if (r.ok || r.status === 201) {
        configId = d.id; pfConfigId = configId; existingSharingSlug = d.sharingSlug;
      } else {
        showAlert(d.detail || d.title || `[${r.status}] Failed to save setup.`, 'error'); return;
      }
    }

    // 2 — Upload frame if new file selected
    if (frameFile) {
      const fd = new FormData(); fd.append('image', frameFile);
      const r = await fetch(`/api/photo-frame/${configId}/frame-image`, { method: 'POST', headers: H, body: fd });
      const text = await r.text().catch(() => '');
      let d = {}; try { d = JSON.parse(text); } catch {}
      if (!r.ok) { showAlert(d.detail || d.title || 'Frame upload failed.', 'error'); return; }
      existingFrameUrl = d.frameImageUrl;
    }

    // 3 — Upload logo if new file selected
    const logoFile = el('logoFile').files[0];
    if (logoFile) {
      const fd = new FormData(); fd.append('image', logoFile);
      await fetch(`/api/photo-frame/${configId}/logo-image`, { method: 'POST', headers: H, body: fd });
    }

    // 4 — Save landing page settings (always, controls publish flag)
    const r = await fetch(`/api/photo-frame/${configId}/landing-page`, {
      method: 'PATCH', headers: HJ,
      body: JSON.stringify({
        templateName:       'default',
        backgroundColor:    '#1a1a2e',
        headlineText:       eventName,
        instructionText:    'Upload your photo and download your framed picture!',
        downloadButtonText: 'Download My Photo',
        publish:            shouldPublish
      })
    });
    const text = await r.text().catch(() => '');
    let d = {}; try { d = JSON.parse(text); } catch {}

    if (r.ok) {
      isEditing = false;
      el('cancelEditBtn').style.display = 'none';
      if (shouldPublish) {
        isPublished = true;
        showLiveBanner(d.sharingSlug || existingSharingSlug);
        showAlert('Kiosk is live! Share the link with your guests.', 'success');
      } else {
        isPublished = false;
        el('editorSection').style.display = 'none';
        el('draftBanner').style.display   = 'block';
        el('liveBanner').style.display    = 'none';
        showAlert('Settings saved as draft.', 'success');
      }
    } else {
      showAlert(d.detail || d.title || `[${r.status}] Failed to save.`, 'error');
    }
  } catch (e) {
    showAlert('Network error: ' + e.message, 'error');
  } finally {
    saveDraftBtn.disabled = publishBtn.disabled = false;
    saveDraftBtn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Save Draft`;
    publishBtn.innerHTML  = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 2L11 13"/><path d="M22 2L15 22 11 13 2 9l20-7z"/></svg> Publish Kiosk`;
  }
}

loadEvents();
</script>
