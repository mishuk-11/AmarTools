@{
    ViewData["Title"] = "Certificates";
    ViewData["ActivePage"] = "certificates";
    Layout = "~/Views/Shared/Tools_Layout.cshtml";
}
<script>Auth.guard('User');</script>

<style>
  .page-title{font-size:20px;font-weight:800;color:#3e256c;margin-bottom:6px;}
  .page-sub{font-size:13px;color:#6b7280;margin-bottom:24px;}
  .card{background:#fff;border:1px solid #ede8f5;border-radius:14px;padding:24px;margin-bottom:20px;}
  .card-title{font-size:14px;font-weight:700;color:#3e256c;margin-bottom:16px;display:flex;align-items:center;gap:8px;}
  .form-group{margin-bottom:14px;}
  .form-label{display:block;font-size:12px;font-weight:700;color:#374151;margin-bottom:5px;text-transform:uppercase;letter-spacing:.3px;}
  .form-input{width:100%;padding:10px 13px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:13px;background:#fafafa;box-sizing:border-box;}
  .form-input:focus{outline:none;border-color:#6252a3;box-shadow:0 0 0 3px rgba(98,82,163,.1);background:#fff;}
  .form-textarea{width:100%;padding:10px 13px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:13px;background:#fafafa;box-sizing:border-box;resize:vertical;min-height:80px;}
  .form-textarea:focus{outline:none;border-color:#6252a3;background:#fff;}
  .btn{padding:9px 18px;border:none;border-radius:9px;font-size:13px;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:opacity .15s;}
  .btn:hover{opacity:.88;}
  .btn-primary{background:linear-gradient(135deg,#3e256c,#6252a3);color:#fff;}
  .btn-ghost{background:#f3f4f6;color:#374151;border:1px solid #e5e7eb;}
  .btn-green{background:linear-gradient(135deg,#166534,#16a34a);color:#fff;}
  .btn-red{background:#fef2f2;color:#991b1b;border:1px solid #fecaca;}
  .select-input{width:100%;padding:10px 13px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:13px;background:#fafafa;box-sizing:border-box;}
  .select-input:focus{outline:none;border-color:#6252a3;}
  .upload-box{border:2px dashed #e5e7eb;border-radius:10px;padding:28px;text-align:center;cursor:pointer;transition:border .15s;}
  .upload-box:hover{border-color:#6252a3;}
  .upload-box input{display:none;}
  .upload-label{font-size:13px;color:#6b7280;cursor:pointer;}
  .alert{padding:11px 14px;border-radius:9px;font-size:13px;margin-bottom:14px;display:none;}
  .alert-success{background:#f0fdf4;color:#166534;border:1px solid #bbf7d0;}
  .alert-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca;}
  .status-banner{border-radius:12px;padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;}
  .banner-saved{background:#f0fdf4;border:1px solid #bbf7d0;}
  .banner-text{font-size:13px;font-weight:600;display:flex;align-items:center;gap:8px;}
  .banner-saved .banner-text{color:#166534;}
  .banner-actions{display:flex;gap:8px;flex-wrap:wrap;}
</style>

<h1 class="page-title">Certificates</h1>
<p class="page-sub">Generate and send personalised certificates to your event attendees.</p>

<div id="alertMsg" class="alert"></div>

<!-- Step 1: Event -->
<div class="card">
  <div class="card-title"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>1 · Select Event</div>
  <div class="form-group">
    <label class="form-label">Active Event</label>
    <select id="eventSelect" class="select-input" onchange="onEventChange()">
      <option value="">— Choose an event —</option>
    </select>
  </div>
</div>

<div id="setupSection" style="display:none;">

  <!-- Saved banner (shown when config exists and not editing) -->
  <div id="savedBanner" class="status-banner banner-saved" style="display:none;">
    <span class="banner-text">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
      Template settings saved
    </span>
    <div class="banner-actions">
      <button class="btn btn-ghost" onclick="editSettings()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Edit Settings
      </button>
    </div>
  </div>

  <!-- Template settings editor (shown when no config, or editing) -->
  <div id="editorCard" class="card">
    <div class="card-title"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>2 · Template Settings</div>
    <div class="form-group"><label class="form-label">Template Name *</label><input id="cTemplateName" class="form-input" placeholder="e.g. Participation Certificate" /></div>
    <div class="form-group"><label class="form-label">Email Subject</label><input id="cEmailSubject" class="form-input" placeholder="e.g. Your Certificate of Participation" /></div>
    <div class="form-group"><label class="form-label">Email Body</label><textarea id="cEmailBody" class="form-textarea" placeholder="Dear {Name}, please find your certificate attached…"></textarea></div>
    <div style="display:flex;gap:10px;flex-wrap:wrap;">
      <button class="btn btn-primary" onclick="saveSettings()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        Save Settings
      </button>
      <button id="cancelEditBtn" class="btn btn-ghost" onclick="cancelEdit()" style="display:none;">Cancel</button>
    </div>
  </div>

  <!-- Upload & Generate (only visible after certConfigId is set) -->
  <div id="actionsSection" style="display:none;">

    <!-- Upload base template -->
    <div class="card">
      <div class="card-title"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>3 · Upload Certificate Template (PDF/Image)</div>
      <p style="font-size:12px;color:#6b7280;margin-bottom:12px;">Upload the certificate design file. Recipient names will be merged into it.</p>
      <div class="upload-box" onclick="document.getElementById('templateFile').click()">
        <input type="file" id="templateFile" accept=".pdf,.png,.jpg,.jpeg" />
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <label class="upload-label" id="templateFileLabel">Click to upload certificate template</label>
      </div>
      <button class="btn btn-primary" style="margin-top:12px;" onclick="uploadTemplate()">Upload Template</button>
    </div>

    <!-- Upload recipients -->
    <div class="card">
      <div class="card-title"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>4 · Upload Recipients (CSV/Excel)</div>
      <p style="font-size:12px;color:#6b7280;margin-bottom:12px;">Upload a CSV with columns: Name, Email (required). Additional columns become merge fields.</p>
      <div class="upload-box" onclick="document.getElementById('recipientFile').click()">
        <input type="file" id="recipientFile" accept=".csv,.xlsx,.xls" />
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <label class="upload-label" id="recipientFileLabel">Click to upload recipient list</label>
      </div>
      <button class="btn btn-primary" style="margin-top:12px;" onclick="uploadRecipients()">Upload Recipients</button>
    </div>

    <!-- Generate -->
    <div class="card">
      <div class="card-title"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>5 · Generate Certificates</div>
      <p style="font-size:12px;color:#6b7280;margin-bottom:16px;">Generate and optionally email all certificates to recipients.</p>
      <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
        <label style="display:flex;align-items:center;gap:7px;font-size:13px;cursor:pointer;">
          <input type="checkbox" id="sendEmails" style="width:15px;height:15px;accent-color:#3e256c;" />
          Send emails to recipients
        </label>
        <button class="btn btn-green" onclick="generateBatch()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          Generate Now
        </button>
      </div>
    </div>

  </div><!-- /actionsSection -->
</div><!-- /setupSection -->

<script>
Auth.guard('User');
const token = Auth.getToken();
const H  = { 'Authorization': `Bearer ${token}` };
const HJ = { ...H, 'Content-Type': 'application/json' };
const CERT_TOOL_TYPE = 2; // ToolType.CertificateGenerator
let selectedEventToolId = null;
let certConfigId = null;
let isEditing = false;

function showAlert(msg, type='success') {
  const el = document.getElementById('alertMsg');
  el.textContent = msg; el.className = `alert alert-${type}`; el.style.display='block';
  setTimeout(()=>el.style.display='none', 4000);
}

function applyUiState() {
  const hasCfg = !!certConfigId;
  document.getElementById('savedBanner').style.display   = hasCfg && !isEditing ? 'flex' : 'none';
  document.getElementById('editorCard').style.display    = !hasCfg || isEditing  ? 'block' : 'none';
  document.getElementById('cancelEditBtn').style.display = hasCfg && isEditing   ? 'inline-flex' : 'none';
  document.getElementById('actionsSection').style.display = hasCfg               ? 'block' : 'none';
}

function editSettings() {
  isEditing = true;
  applyUiState();
}

function cancelEdit() {
  isEditing = false;
  applyUiState();
}

async function loadEvents() {
  try {
    const r = await fetch('/api/events', { headers: H });
    if (!r.ok) return;
    const data = await r.json();
    const sel  = document.getElementById('eventSelect');
    data.filter(e=>e.status===1).forEach(e => {
      const o = document.createElement('option'); o.value=e.id; o.textContent=e.name; sel.appendChild(o);
    });
  } catch {}
}

async function onEventChange() {
  const eventId = document.getElementById('eventSelect').value;
  selectedEventToolId = null;
  certConfigId = null;
  isEditing = false;
  document.getElementById('setupSection').style.display = eventId ? 'block' : 'none';
  if (!eventId) return;

  try {
    const r = await fetch(`/api/events/${eventId}/activate-tool/${CERT_TOOL_TYPE}`, {
      method: 'POST', headers: HJ
    });
    if (r.ok) {
      selectedEventToolId = await r.json();
      try {
        const setup = await fetch(`/api/certificate-generator/setup/${selectedEventToolId}`, { headers: H });
        if (setup.ok) {
          const d = await setup.json();
          certConfigId = d.id;
          document.getElementById('cTemplateName').value = d.templateName || '';
          document.getElementById('cEmailSubject').value = d.emailSubject || '';
          document.getElementById('cEmailBody').value    = d.emailBody    || '';
        }
      } catch {}
      applyUiState();
    } else {
      const e = await r.json().catch(()=>({}));
      showAlert(e.detail || 'Could not activate tool.', 'error');
      document.getElementById('setupSection').style.display = 'none';
    }
  } catch {
    showAlert('Network error activating tool.', 'error');
  }
}

async function saveSettings() {
  if (!selectedEventToolId) { showAlert('Select an event first.','error'); return; }
  const name = document.getElementById('cTemplateName').value.trim();
  if (!name) { showAlert('Template name is required.','error'); return; }
  try {
    const r = await fetch('/api/certificate-generator/setup', {
      method: 'POST', headers: HJ,
      body: JSON.stringify({
        eventToolId:  selectedEventToolId,
        templateName: name,
        emailSubject: document.getElementById('cEmailSubject').value.trim() || null,
        emailBody:    document.getElementById('cEmailBody').value.trim()    || null
      })
    });
    const txt = await r.text();
    let d = {};
    try { d = JSON.parse(txt); } catch {}
    if (r.ok || r.status === 201) {
      certConfigId = d.id;
      isEditing = false;
      showAlert('Settings saved!');
      applyUiState();
    } else {
      showAlert(d.detail || d.title || `Error ${r.status}`, 'error');
    }
  } catch { showAlert('Network error.','error'); }
}

document.getElementById('templateFile').addEventListener('change', () => {
  const f = document.getElementById('templateFile').files[0];
  if (f) document.getElementById('templateFileLabel').textContent = f.name;
});
document.getElementById('recipientFile').addEventListener('change', () => {
  const f = document.getElementById('recipientFile').files[0];
  if (f) document.getElementById('recipientFileLabel').textContent = f.name;
});

async function uploadTemplate() {
  if (!certConfigId) { showAlert('Save settings first.','error'); return; }
  const file = document.getElementById('templateFile').files[0];
  if (!file) { showAlert('Choose a template file.','error'); return; }
  const fd = new FormData(); fd.append('file', file);
  const r = await fetch(`/api/certificate-generator/${certConfigId}/base-template`,{method:'POST',headers:H,body:fd});
  r.ok ? showAlert('Template uploaded!') : showAlert('Upload failed.','error');
}

async function uploadRecipients() {
  if (!certConfigId) { showAlert('Save settings first.','error'); return; }
  const file = document.getElementById('recipientFile').files[0];
  if (!file) { showAlert('Choose a recipient file.','error'); return; }
  const fd = new FormData(); fd.append('file', file);
  const r = await fetch(`/api/certificate-generator/${certConfigId}/recipient-dataset`,{method:'POST',headers:H,body:fd});
  r.ok ? showAlert('Recipients uploaded!') : showAlert('Upload failed.','error');
}

async function generateBatch() {
  if (!certConfigId) { showAlert('Complete setup first.','error'); return; }
  const sendEmails = document.getElementById('sendEmails').checked;
  const r = await fetch(`/api/certificate-generator/${certConfigId}/generate`,{
    method:'POST', headers:HJ, body: JSON.stringify({ sendEmails })
  });
  r.ok ? showAlert('Generation started! Check your email.') : showAlert('Generation failed.','error');
}

loadEvents();
</script>
