<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@(ViewData["Title"] != null ? ViewData["Title"] + " · " : "")AmarTools</title>
  <script src="/js/auth.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --primary:   #3e256c;
      --secondary: #6252a3;
      --accent:    #d7b4d5;
      --surface:   #fef1f0;
      --white:     #ffffff;
      --text:      #1f1635;
      --muted:     #6b7280;
      --border:    #ede8f5;
      --topbar-h:  60px;
      --sidebar-w: 220px;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--surface);
      color: var(--text);
      min-height: 100vh;
    }

    /* ── Top navbar ── */
    .topnav {
      position: fixed; top: 0; left: 0; right: 0;
      height: var(--topbar-h);
      background: rgba(255,255,255,.95);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center;
      justify-content: space-between;
      padding: 0 20px;
      z-index: 200;
      box-shadow: 0 2px 12px rgba(62,37,108,.07);
    }
    .topnav-brand {
      display: flex; align-items: center; gap: 9px;
      text-decoration: none;
    }
    .topnav-logo {
      width: 32px; height: 32px;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-weight: 800; font-size: 11px; letter-spacing: 1px;
    }
    .topnav-title { font-size: 15px; font-weight: 700; color: var(--primary); }
    .topnav-right  { display: flex; align-items: center; gap: 10px; }
    .avatar {
      width: 32px; height: 32px;
      background: linear-gradient(135deg, var(--secondary), var(--accent));
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      color: #fff; font-size: 12px; font-weight: 700;
    }
    .user-name { font-size: 13px; font-weight: 500; color: var(--text); }
    .btn-logout {
      padding: 5px 12px; border: 1.5px solid var(--border); background: #fff;
      border-radius: 8px; font-size: 12px; font-weight: 600; color: var(--primary);
      cursor: pointer; display: flex; align-items: center; gap: 5px; transition: background .15s;
    }
    .btn-logout:hover { background: var(--border); }

    /* ── Sidebar ── */
    .sidebar {
      position: fixed; top: var(--topbar-h); left: 0; bottom: 0;
      width: var(--sidebar-w);
      background: var(--white);
      border-right: 1px solid var(--border);
      overflow-y: auto;
      padding: 16px 10px;
      z-index: 100;
    }
    .side-section {
      font-size: 10px; font-weight: 700; color: #9ca3af;
      text-transform: uppercase; letter-spacing: .6px;
      padding: 12px 10px 5px;
    }
    .side-section:first-child { padding-top: 4px; }
    .side-link {
      display: flex; align-items: center; gap: 9px;
      padding: 8px 10px; border-radius: 8px;
      font-size: 13px; font-weight: 500; color: #374151;
      text-decoration: none; transition: background .12s, color .12s;
      margin-bottom: 1px;
    }
    .side-link:hover  { background: var(--border); color: var(--primary); }
    .side-link.active { background: var(--border); color: var(--primary); font-weight: 700; }
    .side-link svg    { flex-shrink: 0; opacity: .6; }
    .side-link:hover svg, .side-link.active svg { opacity: 1; }

    /* ── Main content ── */
    .content-wrap {
      margin-left: var(--sidebar-w);
      padding-top: var(--topbar-h);
      min-height: 100vh;
    }
    .content-inner {
      padding: 28px 28px;
      max-width: 960px;
    }

    /* ── Mobile ── */
    .mob-toggle {
      display: none; background: none; border: none;
      cursor: pointer; color: var(--primary); padding: 4px; font-size: 20px;
    }
    .sidebar-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,.35); z-index: 90;
    }
    .sidebar-overlay.open { display: block; }

    @@media (max-width: 768px) {
      .sidebar { transform: translateX(-100%); transition: transform .25s; }
      .sidebar.open { transform: translateX(0); }
      .content-wrap { margin-left: 0; }
      .content-inner { padding: 20px 16px; }
      .mob-toggle { display: block; }
      .user-name  { display: none; }
    }
  </style>
</head>
<body>

<!-- ── Top navbar ── -->
<header class="topnav">
  <div style="display:flex;align-items:center;gap:10px;">
    <button class="mob-toggle" onclick="toggleSidebar()" aria-label="Menu">☰</button>
    <a class="topnav-brand" href="/dashboard" id="topBrand">
      <div class="topnav-logo">AT</div>
      <span class="topnav-title">AmarTools</span>
    </a>
  </div>
  <div class="topnav-right" id="topAuth"></div>
</header>

<!-- ── Sidebar ── -->
<aside class="sidebar" id="sidebar">
  <div class="side-section">Menu</div>
  <a class="side-link @(ViewData["ActivePage"]?.ToString() == "dashboard" ? "active" : "")" href="/dashboard">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
    Dashboard
  </a>
  <a class="side-link @(ViewData["ActivePage"]?.ToString() == "events" ? "active" : "")" href="/tools/events">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    My Events
  </a>

  <div class="side-section">Tools</div>
  <a class="side-link @(ViewData["ActivePage"]?.ToString() == "photoframe" ? "active" : "")" href="/tools/photo-frame">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="12" cy="12" r="4"/></svg>
    Photo Frame
  </a>
  <a class="side-link @(ViewData["ActivePage"]?.ToString() == "certificates" ? "active" : "")" href="/tools/certificates">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/></svg>
    Certificates
  </a>
  <a class="side-link @(ViewData["ActivePage"]?.ToString() == "contacts" ? "active" : "")" href="/tools/contacts">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
    Contacts
  </a>
</aside>

<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<!-- ── Page content ── -->
<div class="content-wrap">
  <div class="content-inner">
    @RenderBody()
  </div>
</div>

<script>
  function toggleSidebar() {
    document.getElementById('sidebar').classList.toggle('open');
    document.getElementById('sidebarOverlay').classList.toggle('open');
  }
  function closeSidebar() {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebarOverlay').classList.remove('open');
  }

  // Top-right user info
  (function () {
    var el = document.getElementById('topAuth');
    if (!el) return;
    if (Auth.isLoggedIn()) {
      var u = Auth.getUser();
      var name = u.fullName || 'User';
      el.innerHTML =
        '<div class="avatar">' + name.charAt(0).toUpperCase() + '</div>' +
        '<span class="user-name">' + name + '</span>' +
        '<button class="btn-logout" onclick="Auth.logout()">' +
          '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>' +
          'Sign out</button>';
    }
  })();
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
