@{
    ViewData["Title"] = "Welcome";
    Layout = "~/Views/Shared/User_Layout.cshtml";
}
<script>
  // Redirect authenticated users away from the landing page
  if (typeof Auth !== 'undefined' && Auth.isLoggedIn() && !Auth.isExpired()) {
    window.location.replace(Auth.isAdmin() ? '/admin' : '/dashboard');
  }
</script>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 24px 60px;
  }

  .hero-badge {
    display: inline-block;
    background: #ede8f5;
    color: #3e256c;
    font-size: 12px;
    font-weight: 700;
    padding: 5px 14px;
    border-radius: 20px;
    margin-bottom: 24px;
    border: 1px solid #d7b4d5;
    text-transform: uppercase;
    letter-spacing: .5px;
  }

  .hero h1 {
    font-size: clamp(32px, 6vw, 52px);
    font-weight: 800;
    color: #3e256c;
    line-height: 1.15;
    margin-bottom: 16px;
    max-width: 640px;
  }

  .hero h1 span {
    background: linear-gradient(135deg, #6252a3, #d7b4d5);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero p {
    font-size: 17px;
    color: #6b7280;
    max-width: 480px;
    line-height: 1.65;
    margin-bottom: 40px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn {
    padding: 13px 28px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: transform .15s, box-shadow .15s;
    border: none;
    cursor: pointer;
  }
  .btn:hover { transform: translateY(-2px); }

  .btn-primary {
    background: linear-gradient(135deg, #3e256c, #6252a3);
    color: #fff;
    box-shadow: 0 4px 16px rgba(62,37,108,.3);
  }
  .btn-primary:hover { box-shadow: 0 8px 24px rgba(62,37,108,.4); }

  .btn-outline {
    background: #fff;
    color: #3e256c;
    border: 2px solid #ede8f5;
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    margin-top: 72px;
    max-width: 900px;
    width: 100%;
  }

  .feature-card {
    background: #fff;
    border: 1px solid #ede8f5;
    border-radius: 14px;
    padding: 24px 20px;
    text-align: left;
    transition: box-shadow .2s, transform .2s;
  }
  .feature-card:hover {
    box-shadow: 0 8px 32px rgba(62,37,108,.12);
    transform: translateY(-3px);
  }

  .feature-icon {
    width: 44px;
    height: 44px;
    background: linear-gradient(135deg, #3e256c15, #6252a325);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
    color: #6252a3;
  }

  .feature-card h3 {
    font-size: 15px;
    font-weight: 700;
    color: #3e256c;
    margin-bottom: 6px;
  }

  .feature-card p {
    font-size: 13px;
    color: #6b7280;
    line-height: 1.55;
  }
</style>

<div class="hero">
  <span class="hero-badge">Event Management Platform</span>
  <h1>Run better events with <span>AmarTools</span></h1>
  <p>Photo frames, certificates, contact books, voting — everything your event team needs, in one place.</p>
  <div class="hero-actions">
    <a href="/register" class="btn btn-primary">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
      Get started
    </a>
    <a href="/login" class="btn btn-outline">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
      Sign in
    </a>
  </div>

  <div class="features">
    <div class="feature-card">
      <div class="feature-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="12" cy="12" r="4"/></svg>
      </div>
      <h3>Photo Frames</h3>
      <p>Let guests snap and overlay branded frames instantly at your event kiosk.</p>
    </div>

    <div class="feature-card">
      <div class="feature-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/></svg>
      </div>
      <h3>Certificates</h3>
      <p>Generate and bulk-email personalised certificates from uploaded templates.</p>
    </div>

    <div class="feature-card">
      <div class="feature-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <h3>Contact Book</h3>
      <p>Manage your event attendees and coordinators in a centralised directory.</p>
    </div>

    <div class="feature-card">
      <div class="feature-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      </div>
      <h3>Multi-tenant</h3>
      <p>Each event firm gets its own isolated workspace with full RBAC control.</p>
    </div>
  </div>
</div>
