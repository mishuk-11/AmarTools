@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/Admin_Layout.cshtml";
}

<style>
  .section-title {
    font-size: 15px; font-weight: 700; color: #3e256c;
    margin: 28px 0 14px; display: flex; align-items: center; gap: 8px;
  }
  .section-title:first-of-type { margin-top: 0; }

  /* ── Stat cards ── */
  .stat-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 14px; margin-bottom: 28px;
  }
  .stat-card {
    background: #fff; border: 1px solid #ede8f5;
    border-radius: 12px; padding: 18px 16px;
  }
  .stat-label { font-size: 11px; font-weight: 700; color: #9ca3af; text-transform: uppercase; letter-spacing: .4px; }
  .stat-value { font-size: 28px; font-weight: 800; color: #3e256c; margin-top: 4px; line-height: 1; }
  .stat-sub   { font-size: 11px; color: #9ca3af; margin-top: 4px; }

  /* ── Tables ── */
  .table-wrap {
    background: #fff; border: 1px solid #ede8f5;
    border-radius: 14px; overflow: hidden; margin-bottom: 32px;
  }
  .data-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .data-table th {
    background: #f8f5ff; color: #6b7280; font-weight: 700;
    padding: 11px 16px; text-align: left; border-bottom: 1px solid #ede8f5;
    text-transform: uppercase; font-size: 11px; letter-spacing: .4px;
  }
  .data-table td {
    padding: 13px 16px; border-bottom: 1px solid #f3f4f6;
    color: #374151; vertical-align: middle;
  }
  .data-table tr:last-child td { border-bottom: none; }
  .data-table tr:hover td { background: #fafafa; }

  /* ── Badges ── */
  .badge {
    display: inline-flex; align-items: center; padding: 3px 9px;
    border-radius: 20px; font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .3px;
  }
  .badge-active   { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
  .badge-archived { background: #f3f4f6; color: #374151; border: 1px solid #e5e7eb; }
  .badge-closed   { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }
  .badge-pending  { background: #fef9c3; color: #854d0e; border: 1px solid #fde68a; }
  .badge-sub      { background: #ede8f5; color: #6252a3; border: 1px solid #d7b4d5; }
  .badge-nosub    { background: #f3f4f6; color: #9ca3af; border: 1px solid #e5e7eb; }
  .badge-7        { background: #f3f4f6; color: #374151; border: 1px solid #e5e7eb; }
  .badge-30       { background: #ede8f5; color: #6252a3; border: 1px solid #d7b4d5; }
  .badge-90       { background: #fdf4ff; color: #3e256c; border: 1px solid #d7b4d5; }

  /* ── Approve / Reject / Action buttons ── */
  .btn-approve, .btn-reject, .btn-action {
    padding: 5px 12px; border: none; border-radius: 7px;
    font-size: 12px; font-weight: 700; cursor: pointer; transition: opacity .15s;
  }
  .btn-approve { background: #dcfce7; color: #166534; }
  .btn-reject  { background: #fef2f2; color: #991b1b; margin-left: 5px; }
  .btn-approve:hover { background: #bbf7d0; }
  .btn-reject:hover  { background: #fecaca; }
  .btn-approve:disabled, .btn-reject:disabled { opacity: .5; cursor: not-allowed; }
  .btn-rem-admin    { background: #fef9c3; color: #854d0e; margin-right:4px; }
  .btn-rem-admin:hover { background: #fde68a; }
  .btn-ban          { background: #fef2f2; color: #991b1b; margin-right:4px; }
  .btn-ban:hover    { background: #fecaca; }
  .btn-unban        { background: #f0fdf4; color: #166534; margin-right:4px; }
  .btn-unban:hover  { background: #bbf7d0; }
  .btn-create-admin { background: #ede8f5; color: #3e256c; border: none; border-radius: 8px; padding: 6px 14px; font-size: 12px; font-weight: 700; cursor: pointer; }
  .btn-create-admin:hover { background: #d7b4d5; }
  .badge-admin { background: #ede8f5; color: #3e256c; border: 1px solid #d7b4d5; }
  .badge-banned { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }

  .notes-input {
    padding: 5px 9px; border: 1.5px solid #e5e7eb; border-radius: 7px;
    font-size: 12px; width: 160px; background: #fafafa;
  }
  .notes-input:focus { outline: none; border-color: #6252a3; }

  /* ── Empty state ── */
  .empty-state {
    padding: 40px 24px; text-align: center; color: #9ca3af; font-size: 13px;
  }
  .empty-icon {
    width: 44px; height: 44px; background: #f3f4f6; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 10px; color: #d1d5db;
  }
</style>

<script>Auth.guard('Admin');</script>

<!-- ── Stats ─────────────────────────────────────────────────────────────── -->
<p class="section-title">Overview</p>
<div class="stat-row">
  <div class="stat-card">
    <div class="stat-label">Pending Requests</div>
    <div class="stat-value" id="statPending">—</div>
    <div class="stat-sub">Awaiting review</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Total Users</div>
    <div class="stat-value" id="statUsers">—</div>
    <div class="stat-sub">Registered accounts</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Subscribed Users</div>
    <div class="stat-value" id="statSubbed">—</div>
    <div class="stat-sub">Active subscriptions</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Total Events</div>
    <div class="stat-value" id="statEvents">—</div>
    <div class="stat-sub">All workspaces</div>
  </div>
</div>

<!-- ── Pending Subscription Requests ─────────────────────────────────────── -->
<p class="section-title">
  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
  Pending Subscription Requests
</p>
<div class="table-wrap">
  <table class="data-table">
    <thead>
      <tr>
        <th>User</th><th>Email</th><th>Package</th>
        <th>Requested</th><th>Notes</th><th>Actions</th>
      </tr>
    </thead>
    <tbody id="requestsBody">
      <tr><td colspan="6"><div class="empty-state">Loading…</div></td></tr>
    </tbody>
  </table>
</div>

<!-- ── All Events ─────────────────────────────────────────────────────────── -->
<p class="section-title">
  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
  All Events
</p>
<div class="table-wrap">
  <table class="data-table">
    <thead>
      <tr>
        <th>Event Name</th><th>Owner</th><th>Status</th>
        <th>Event Date</th><th>Venue</th><th>Created</th>
      </tr>
    </thead>
    <tbody id="eventsBody">
      <tr><td colspan="6"><div class="empty-state">Loading…</div></td></tr>
    </tbody>
  </table>
</div>

<!-- ── Users & Subscriptions ─────────────────────────────────────────────── -->
<div style="display:flex;align-items:center;justify-content:space-between;margin:28px 0 14px;">
  <p class="section-title" style="margin:0;">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    Users &amp; Subscriptions
  </p>
  <button class="btn-create-admin" onclick="openCreateAdminModal()">
    + Create Admin
  </button>
</div>
<div class="table-wrap">
  <table class="data-table">
    <thead>
      <tr>
        <th>Name</th><th>Email</th><th>Role / Status</th>
        <th>Subscription</th><th>Expires</th><th>Registered</th><th>Actions</th>
      </tr>
    </thead>
    <tbody id="usersBody">
      <tr><td colspan="7"><div class="empty-state">Loading…</div></td></tr>
    </tbody>
  </table>
</div>

<!-- Ban modal -->
<div id="banModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:600;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:16px;padding:28px;max-width:380px;width:90%;box-shadow:0 20px 60px rgba(62,37,108,.2);">
    <div style="font-size:16px;font-weight:800;color:#3e256c;margin-bottom:16px;">Ban User</div>
    <input type="hidden" id="banUserId" />
    <div style="margin-bottom:14px;">
      <label style="display:block;font-size:12px;font-weight:700;color:#374151;margin-bottom:5px;text-transform:uppercase;">Ban Duration</label>
      <select id="banDuration" style="width:100%;padding:10px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:13px;background:#fafafa;">
        <option value="">Permanent ban</option>
        <option value="1">1 day</option>
        <option value="7">7 days</option>
        <option value="30">30 days</option>
        <option value="90">90 days</option>
        <option value="365">1 year</option>
      </select>
    </div>
    <div style="display:flex;gap:10px;justify-content:flex-end;">
      <button onclick="document.getElementById('banModal').style.display='none'" style="padding:9px 18px;border:1px solid #e5e7eb;border-radius:9px;background:#f3f4f6;font-size:13px;font-weight:700;cursor:pointer;">Cancel</button>
      <button onclick="confirmBan()" style="padding:9px 18px;border:none;border-radius:9px;background:#dc2626;color:#fff;font-size:13px;font-weight:700;cursor:pointer;">Ban User</button>
    </div>
  </div>
</div>

<!-- Create Admin modal -->
<div id="createAdminModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:600;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:16px;padding:28px;max-width:420px;width:90%;box-shadow:0 20px 60px rgba(62,37,108,.2);">
    <div style="font-size:16px;font-weight:800;color:#3e256c;margin-bottom:6px;">Create Admin Account</div>
    <p style="font-size:12px;color:#6b7280;margin-bottom:18px;">Create a new administrator account with email and password.</p>
    <div id="createAdminError" style="display:none;background:#fef2f2;color:#991b1b;border:1px solid #fecaca;border-radius:8px;padding:9px 12px;font-size:12px;margin-bottom:14px;"></div>
    <div style="margin-bottom:12px;">
      <label style="display:block;font-size:12px;font-weight:700;color:#374151;margin-bottom:5px;text-transform:uppercase;">Full Name</label>
      <input id="caFullName" type="text" placeholder="Admin Name" style="width:100%;padding:10px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:13px;background:#fafafa;box-sizing:border-box;" />
    </div>
    <div style="margin-bottom:12px;">
      <label style="display:block;font-size:12px;font-weight:700;color:#374151;margin-bottom:5px;text-transform:uppercase;">Email Address</label>
      <input id="caEmail" type="email" placeholder="admin@example.com" style="width:100%;padding:10px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:13px;background:#fafafa;box-sizing:border-box;" />
    </div>
    <div style="margin-bottom:20px;">
      <label style="display:block;font-size:12px;font-weight:700;color:#374151;margin-bottom:5px;text-transform:uppercase;">Password</label>
      <input id="caPassword" type="password" placeholder="Strong password…" style="width:100%;padding:10px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:13px;background:#fafafa;box-sizing:border-box;" />
    </div>
    <div style="display:flex;gap:10px;justify-content:flex-end;">
      <button onclick="closeCreateAdminModal()" style="padding:9px 18px;border:1px solid #e5e7eb;border-radius:9px;background:#f3f4f6;font-size:13px;font-weight:700;cursor:pointer;">Cancel</button>
      <button onclick="confirmCreateAdmin()" id="caSubmitBtn" style="padding:9px 18px;border:none;border-radius:9px;background:#3e256c;color:#fff;font-size:13px;font-weight:700;cursor:pointer;">Create Admin</button>
    </div>
  </div>
</div>

<script>
const token   = Auth.getToken();
const h       = { 'Authorization': `Bearer ${token}` };
const myId    = (Auth.getUser()?.id || '').toLowerCase();

function esc(s) {
  return String(s ?? '—').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
function fmtDate(iso) {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' });
}
function empty(msg) {
  return `<div class="empty-state"><div class="empty-icon">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg></div>${esc(msg)}</div>`;
}

// ── Stats ────────────────────────────────────────────────────────────────────
async function loadStats() {
  try {
    const r = await fetch('/api/admin/stats', { headers: h });
    if (!r.ok) return;
    const d = await r.json();
    document.getElementById('statPending').textContent = d.pendingRequests;
    document.getElementById('statUsers').textContent   = d.totalUsers;
    document.getElementById('statSubbed').textContent  = d.subscribedUsers;
    document.getElementById('statEvents').textContent  = d.totalEvents;
  } catch {}
}

// ── Pending requests ─────────────────────────────────────────────────────────
async function loadRequests() {
  const tbody = document.getElementById('requestsBody');
  try {
    const r = await fetch('/api/subscriptionrequest/admin', { headers: h });
    if (r.status === 401 || r.status === 403) { window.location.href = '/login'; return; }
    const data = await r.json();

    if (!data.length) {
      tbody.innerHTML = `<tr><td colspan="6">${empty('No pending requests')}</td></tr>`;
      return;
    }
    tbody.innerHTML = data.map(r => `
      <tr id="row-${r.id}">
        <td><strong>${esc(r.userName)}</strong></td>
        <td>${esc(r.userEmail)}</td>
        <td><span class="badge badge-${r.packageDays}">${r.packageDays} days</span></td>
        <td>${fmtDate(r.requestedAt)}</td>
        <td><input class="notes-input" id="notes-${r.id}" type="text" placeholder="Optional note…"/></td>
        <td>
          <button class="btn-approve" onclick="review('${r.id}','approve')">Approve</button>
          <button class="btn-reject"  onclick="review('${r.id}','reject')">Reject</button>
        </td>
      </tr>`).join('');
  } catch {
    tbody.innerHTML = `<tr><td colspan="6">${empty('Failed to load requests')}</td></tr>`;
  }
}

async function review(id, action) {
  const notes = document.getElementById(`notes-${id}`)?.value.trim() || null;
  const row   = document.getElementById(`row-${id}`);
  row?.querySelectorAll('button').forEach(b => b.disabled = true);
  try {
    const r = await fetch(`/api/subscriptionrequest/${id}/${action}`, {
      method: 'PUT',
      headers: { ...h, 'Content-Type': 'application/json' },
      body: JSON.stringify({ notes })
    });
    if (r.ok || r.status === 204) {
      row?.remove();
      const left = document.querySelectorAll('#requestsBody tr[id]').length;
      document.getElementById('statPending').textContent = left;
      if (!left) loadRequests();
      loadStats();
    } else {
      const err = await r.json().catch(() => ({}));
      alert(err.detail || 'Action failed.');
      row?.querySelectorAll('button').forEach(b => b.disabled = false);
    }
  } catch {
    alert('Network error.');
    row?.querySelectorAll('button').forEach(b => b.disabled = false);
  }
}

// ── Events ───────────────────────────────────────────────────────────────────
async function loadEvents() {
  const tbody = document.getElementById('eventsBody');
  try {
    const r = await fetch('/api/admin/events', { headers: h });
    if (!r.ok) { tbody.innerHTML = `<tr><td colspan="6">${empty('Failed to load events')}</td></tr>`; return; }
    const data = await r.json();
    if (!data.length) { tbody.innerHTML = `<tr><td colspan="6">${empty('No events yet')}</td></tr>`; return; }
    tbody.innerHTML = data.map(e => `
      <tr>
        <td><strong>${esc(e.name)}</strong>${e.description ? `<br><span style="font-size:11px;color:#9ca3af">${esc(e.description)}</span>` : ''}</td>
        <td>${esc(e.ownerName)}<br><span style="font-size:11px;color:#9ca3af">${esc(e.ownerEmail)}</span></td>
        <td><span class="badge badge-${e.status.toLowerCase()}">${esc(e.status)}</span></td>
        <td>${e.eventDate ? fmtDate(e.eventDate) : '—'}</td>
        <td>${esc(e.venue)}</td>
        <td>${fmtDate(e.createdAt)}</td>
      </tr>`).join('');
  } catch {
    tbody.innerHTML = `<tr><td colspan="6">${empty('Failed to load events')}</td></tr>`;
  }
}

// ── Users ────────────────────────────────────────────────────────────────────
async function loadUsers() {
  const tbody = document.getElementById('usersBody');
  try {
    const r = await fetch('/api/admin/users', { headers: h });
    if (!r.ok) { tbody.innerHTML = `<tr><td colspan="7">${empty('Failed to load users')}</td></tr>`; return; }
    const data = await r.json();
    if (!data.length) { tbody.innerHTML = `<tr><td colspan="7">${empty('No users yet')}</td></tr>`; return; }
    tbody.innerHTML = data.map(u => {
      const initial = esc((u.fullName||'?').charAt(0).toUpperCase());
      const roleBadge = u.isAdmin
        ? '<span class="badge badge-admin">Admin</span>'
        : '<span class="badge badge-7">Owner</span>';
      const banBadge = u.isBanned
        ? (u.banIsPermanent
          ? ' <span class="badge badge-banned">Banned</span>'
          : ` <span class="badge badge-banned">Banned until ${fmtDate(u.banUntil)}</span>`)
        : '';
      const isSelf = u.id.toLowerCase() === myId;
      const adminBtn = (!isSelf && u.isAdmin)
        ? `<button class="btn-action btn-rem-admin" onclick="removeAdmin('${u.id}')">Remove Admin</button>`
        : '';
      const banBtn = isSelf ? '' : (u.isBanned
        ? `<button class="btn-action btn-unban" onclick="unbanUser('${u.id}')">Unban</button>`
        : `<button class="btn-action btn-ban" onclick="openBanModal('${u.id}')">Ban</button>`);
      return `<tr id="urow-${u.id}">
        <td>
          <div style="display:flex;align-items:center;gap:9px;">
            <div style="width:30px;height:30px;background:linear-gradient(135deg,#6252a3,#d7b4d5);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:11px;font-weight:700;flex-shrink:0;">${initial}</div>
            <strong>${esc(u.fullName)}</strong>
          </div>
        </td>
        <td>${esc(u.email)}</td>
        <td>${roleBadge}${banBadge}</td>
        <td>${u.hasSubscription ? '<span class="badge badge-sub">Active</span>' : '<span class="badge badge-nosub">None</span>'}</td>
        <td>${u.hasSubscription && u.subExpiresAt ? fmtDate(u.subExpiresAt) : '—'}</td>
        <td>${fmtDate(u.createdAt)}</td>
        <td style="white-space:nowrap;">${adminBtn}${banBtn}</td>
      </tr>`;
    }).join('');
  } catch {
    tbody.innerHTML = `<tr><td colspan="7">${empty('Failed to load users')}</td></tr>`;
  }
}

async function removeAdmin(id) {
  if (!confirm('Remove Admin role from this user?')) return;
  const r = await fetch(`/api/admin/users/${id}/remove-admin`, { method:'POST', headers: h });
  if (r.ok) { loadUsers(); return; }
  const err = await r.json().catch(() => ({}));
  alert(err.detail || 'Failed to remove admin role.');
}
function openBanModal(id) {
  document.getElementById('banUserId').value = id;
  document.getElementById('banDuration').value = '';
  document.getElementById('banModal').style.display = 'flex';
}
async function confirmBan() {
  const id   = document.getElementById('banUserId').value;
  const days = document.getElementById('banDuration').value;
  document.getElementById('banModal').style.display = 'none';
  const r = await fetch(`/api/admin/users/${id}/ban`, {
    method: 'POST',
    headers: { ...h, 'Content-Type': 'application/json' },
    body: JSON.stringify({ days: days ? parseInt(days) : null })
  });
  if (r.ok) { loadUsers(); return; }
  const err = await r.json().catch(() => ({}));
  alert(err.detail || 'Failed to ban user.');
}
async function unbanUser(id) {
  if (!confirm('Remove ban from this user?')) return;
  const r = await fetch(`/api/admin/users/${id}/unban`, { method:'POST', headers: h });
  r.ok ? loadUsers() : alert('Failed to unban user.');
}

function openCreateAdminModal() {
  document.getElementById('caFullName').value  = '';
  document.getElementById('caEmail').value     = '';
  document.getElementById('caPassword').value  = '';
  document.getElementById('createAdminError').style.display = 'none';
  document.getElementById('createAdminModal').style.display = 'flex';
}
function closeCreateAdminModal() {
  document.getElementById('createAdminModal').style.display = 'none';
}
async function confirmCreateAdmin() {
  const fullName = document.getElementById('caFullName').value.trim();
  const email    = document.getElementById('caEmail').value.trim();
  const password = document.getElementById('caPassword').value;
  const errEl    = document.getElementById('createAdminError');
  const btn      = document.getElementById('caSubmitBtn');

  errEl.style.display = 'none';
  if (!fullName || !email || !password) {
    errEl.textContent = 'All fields are required.';
    errEl.style.display = 'block';
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Creating…';
  try {
    const r = await fetch('/api/admin/create-admin', {
      method: 'POST',
      headers: { ...h, 'Content-Type': 'application/json' },
      body: JSON.stringify({ fullName, email, password })
    });
    if (r.ok) {
      closeCreateAdminModal();
      loadUsers();
      loadStats();
    } else {
      const err = await r.json().catch(() => ({}));
      errEl.textContent = err.detail || 'Failed to create admin.';
      errEl.style.display = 'block';
    }
  } catch {
    errEl.textContent = 'Network error. Please try again.';
    errEl.style.display = 'block';
  } finally {
    btn.disabled = false;
    btn.textContent = 'Create Admin';
  }
}

// Load everything on page load
